# Copy this file to .env and adjust before your event.

# Public URL where users open the app (used for Google OAuth redirects).
# Dev: http://localhost:5173   Production: https://your-domain.example
PUBLIC_URL=http://localhost:5173

# Google OAuth (optional — enables "Continue with Google" on organiser login).
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {PUBLIC_URL}/api/admin/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Port the server listens on (default 3000).
PORT=3000

# Where the SQLite database file lives (relative paths resolve from the start
# directory). Default: ./data.db
# Restrict file permissions on the server — it stores password hashes.
DB_PATH=data.db

# Security notes for internet exposure:
# - Always put HTTPS in front of this app (Caddy, nginx, Cloudflare, etc.).
# - Organisers register with email/password or Google; each owns their tournaments.
# - Participants use the tournament name + participant password on the home page.
