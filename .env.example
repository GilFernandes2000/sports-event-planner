# Copy this file to .env and adjust before your event.

# Password the organiser types in the app to manage players, teams and scores.
# IMPORTANT: set this to something only you know.
ADMIN_PASSWORD=changeme

# Port the server listens on (default 3000).
PORT=3000

# Where the SQLite database file lives (relative paths resolve from the start
# directory). Default: ./data.db
DB_PATH=data.db
